# Public URL of the deployed app (used for OG meta tags)
# Example: https://my-app.vercel.app or https://my-domain.com
VITE_APP_URL=https://your-domain.com

# Supabase project credentials
# Copy this file to .env and fill in your values from:
# https://supabase.com/dashboard/project/<your-project>/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Functions CORS — comma-separated list of allowed origins
# Set this as a secret in Supabase Edge Functions settings.
# If not set, only localhost:5173 and localhost:3000 are allowed.
# Example: https://my-app.vercel.app,https://my-domain.com
# ALLOWED_ORIGINS=https://my-app.vercel.app

# Web Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# Public key goes here (safe for frontend):
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Private key + subject go in Supabase Edge Function Secrets:
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_SUBJECT=mailto:your-email@domain.com
